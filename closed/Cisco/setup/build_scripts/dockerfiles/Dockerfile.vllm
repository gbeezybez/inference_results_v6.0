ARG BASE_IMAGE
FROM $BASE_IMAGE

# Clear any pip/proxy settings from base image and set correct proxy
ENV http_proxy=http://173.36.224.108:80/
ENV https_proxy=http://173.36.224.108:80/
ENV HTTP_PROXY=http://173.36.224.108:80/
ENV HTTPS_PROXY=http://173.36.224.108:80/
ENV PIP_PROXY=http://173.36.224.108:80/
RUN rm -f /root/.config/pip/pip.conf /etc/pip.conf /root/.pip/pip.conf /etc/xdg/pip/pip.conf 2>/dev/null || true \
 && mkdir -p /root/.config/pip \
 && printf '[global]\nproxy = http://173.36.224.108:80/\n' > /root/.config/pip/pip.conf

ARG DEBIAN_FRONTEND=noninteractive
ARG VLLM_DIR=setup/vllm
ARG GPU_ARCH

# Re-install vllm
COPY ${VLLM_DIR} /lab-mlperf-inference/vllm
RUN cd /lab-mlperf-inference/vllm \
    && python3 -m pip uninstall -y vllm \
    && rm -rf /app/vllm/ \
    && rm -rf /root/.cache/vllm/ \
    && python3 setup.py clean --all  \
    && python3 -m pip install -r requirements/rocm.txt \
    && GPU_TARGETS=${GPU_ARCH} SCCACHE_IDLE_TIMEOUT=1800 python3 setup.py develop

WORKDIR /lab-mlperf-inference/submission/
