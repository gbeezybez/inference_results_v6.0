ARG BASE_IMAGE=rocm/pytorch:rocm7.0.2_ubuntu24.04_py3.12_pytorch_release_2.8.0
FROM $BASE_IMAGE

ARG DEBIAN_FRONTEND=noninteractive
ARG VLLM_DIR=setup/vllm
ARG GPU_ARCH

# Re-install vllm
COPY ${VLLM_DIR} /lab-mlperf-inference/vllm
RUN cd /lab-mlperf-inference/vllm \
    && python3 -m pip uninstall -y vllm \
    && rm -rf /app/vllm/ \
    && rm -rf /root/.cache/vllm/ \
    && python3 setup.py clean --all  \
    && python3 -m pip install -r requirements/rocm.txt \
    && GPU_TARGETS=${GPU_ARCH} SCCACHE_IDLE_TIMEOUT=1800 python3 setup.py develop

WORKDIR /lab-mlperf-inference/submission/
