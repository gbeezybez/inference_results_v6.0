#!/bin/bash

# Validate and set Tensor parallel and Instances
export TP=1
export NUM_INSTS=1

if (( XPU_COUNT > 0 )); then
    # XPU
    export TP=1
    export NUM_INSTS=$((XPU_COUNT / (TP*PP)))
    if (( XPU_DEVICE_ID == 57891 )); then
        # B70
        export BATCH_SIZE=384
        export MAX_NUM_BATCHED_TOKENS=512
        export GPU_MEMORY_UTILIZATION=0.90
    elif (( XPU_DEVICE_ID == 57873 )); then
        # B60
        export BATCH_SIZE=256
        export MAX_NUM_BATCHED_TOKENS=768
        export GPU_MEMORY_UTILIZATION=0.9
    elif (( XPU_DEVICE_ID == 57874 )); then
        # B50
        export BATCH_SIZE=128
        export MAX_NUM_BATCHED_TOKENS=256
        export GPU_MEMORY_UTILIZATION=0.85
    else
        echo "Error: XPU device ID $XPU_DEVICE_ID is not in allowed set (${XPU_SUPPORTED_DEVICE_IDS[*]})."
        return 1
    fi
else
    # CPU
    echo "Error: No XPU found. CPU is not enabled for this scenario"
fi
