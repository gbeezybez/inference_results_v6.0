ARG BASE_IMAGE
FROM $BASE_IMAGE

ARG DEBIAN_FRONTEND=noninteractive
ARG VERSION=0.10

WORKDIR /lab-mlperf-inference/
USER root

RUN pip uninstall -y cmake
RUN apt update && apt install -y unzip nano cmake

RUN pip install \
accelerate==1.12.0 \
datasets==4.4.1 \
evaluate==0.4.6 \
numpy==2.1.3 \
py-libnuma==1.2 \
onnx==1.19.0 \
onnxruntime==1.22.1 \
onnxruntime_genai==0.9.2 \
onnxruntime_extensions==0.14.0 \
onnxsim==0.4.36 \
rouge_score==0.1.2 \
transformers==4.57.3 \
mlc-scripts==1.1.0

RUN curl https://rclone.org/install.sh | bash \
&& rclone config create mlc-inference s3 provider=Cloudflare access_key_id=f65ba5eef400db161ea49967de89f47b secret_access_key=fbea333914c292b854f14d3fe232bad6c5407bf0ab1bebf78833c2b359bdfd2b endpoint=https://c2686074cb2caf5cbaf6d134bdba8b47.r2.cloudflarestorage.com

RUN wget https://download.amd.com/opendownload/Quark/amd_quark-${VERSION}.zip && unzip amd_quark-${VERSION}.zip;
RUN set -eux; \
    case "$VERSION" in \
      "0.11") \
      pip install lm_eval; \
      sed -i '316,324d' amd_quark-0.11/examples/torch/language_modeling/llm_ptq/quantize_quark.py; \
      sed -i "152,160c\    from calib import get_mlperf_data\n    calib_dataloader = get_mlperf_data(data_path=args.dataset, tokenizer=tokenizer, batch_size=args.batch_size, num_calib_data=args.num_calib_data, seqlen=args.seq_len, device=main_device,)" amd_quark-0.11/examples/torch/language_modeling/llm_ptq/quantize_quark.py; \
      ;; \
      "0.10") \
      sed -i '294,302d' amd_quark-0.10/examples/torch/language_modeling/llm_ptq/quantize_quark.py; \
      sed -i '241a\    elif dataset_name.endswith('\''pkl'\''):\n        from calib import get_mlperf_data\n        return get_mlperf_data(dataset_name, **kwargs)' amd_quark-0.10/examples/torch/language_modeling/llm_utils/data_preparation.py; \
      ;; \
      *) \
      echo "Unsupported VERSION: $VERSION"; \
      exit 1; \
      ;; \
    esac

COPY tools/calib.py amd_quark-${VERSION}/examples/torch/language_modeling/llm_ptq/
RUN pip install amd_quark-${VERSION}/amd_quark-${VERSION}-py3-none-any.whl
